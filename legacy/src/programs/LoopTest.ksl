  📌("Counter", value: -1);
};

➔ 👤("TEST_AGENT") {
  ➔ 🔗("LOOP_CONCEPT_INHERIT", mode: "Inheritance") 🔑 [@"LOOP_CONCEPT"];
  🧠("LOOP_CONCEPT", name: "Loop Test") {
    📌("Counter", value: λ(ctx.Counter + 1));
  };
  ➔ 🔃 ("LOOP_AGENT", goto: "LOOP_CONCEPT", cycles: 3) 🔑 [@"TEST_AGENT"::"LOOP_CONCEPT"];
